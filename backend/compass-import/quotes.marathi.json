[
  {
    "text": "वाचन म्हणजे स्वतःला नव्याने भेटण्याचा शांत प्रवास.",
    "author": "ग्रंथमित्र",
    "bookId": "69beeec9b277ab5c982c8ed9",
    "bookTitle": "युगान्त",
    "category": "inspiration",
    "tags": ["वाचन", "प्रेरणा", "आत्मचिंतन"],
    "likes": 142,
    "language": "marathi",
    "createdAt": {"$date": "2026-03-01T07:15:00.000Z"},
    "updatedAt": {"$date": "2026-03-01T07:15:00.000Z"}
  },
  {
    "text": "पुस्तकांच्या सहवासात मनाला शब्दांची नव्हे, अर्थांची सवय लागते.",
    "author": "इरावती कर्वे",
    "bookId": "69beeec9b277ab5c982c8ed9",
    "bookTitle": "युगान्त",
    "category": "wisdom",
    "tags": ["चिंतन", "साहित्य", "ज्ञान"],
    "likes": 231,
    "language": "marathi",
    "createdAt": {"$date": "2026-03-02T08:20:00.000Z"},
    "updatedAt": {"$date": "2026-03-02T08:20:00.000Z"}
  },
  {
    "text": "आईची माया आणि पुस्तकांची काया, दोन्ही माणसाला आतून घडवतात.",
    "author": "साने गुरुजी",
    "bookId": "69beeec9b277ab5c982c8edc",
    "bookTitle": "श्यामची आई",
    "category": "emotion",
    "tags": ["आई", "मूल्ये", "संस्कार"],
    "likes": 198,
    "language": "marathi",
    "createdAt": {"$date": "2026-03-03T09:10:00.000Z"},
    "updatedAt": {"$date": "2026-03-03T09:10:00.000Z"}
  },
  {
    "text": "ज्या पानावर डोळे थांबतात, तिथे अनेकदा आयुष्य पुढे चालू होत असते.",
    "author": "ग्रंथमित्र",
    "bookId": "69beeec9b277ab5c982c8edf",
    "bookTitle": "मृत्युंजय",
    "category": "reflection",
    "tags": ["जीवन", "पाने", "अनुभव"],
    "likes": 167,
    "language": "marathi",
    "createdAt": {"$date": "2026-03-04T06:45:00.000Z"},
    "updatedAt": {"$date": "2026-03-04T06:45:00.000Z"}
  },
  {
    "text": "धैर्य हे नेहमी रणांगणात दिसत नाही; ते अनेकदा मनाच्या शांततेत सापडते.",
    "author": "शिवाजी सावंत",
    "bookId": "69beeec9b277ab5c982c8edf",
    "bookTitle": "मृत्युंजय",
    "category": "motivation",
    "tags": ["धैर्य", "कर्ण", "संघर्ष"],
    "likes": 284,
    "language": "marathi",
    "createdAt": {"$date": "2026-03-05T10:00:00.000Z"},
    "updatedAt": {"$date": "2026-03-05T10:00:00.000Z"}
  },
  {
    "text": "वाचकाला प्रत्येक चांगले पुस्तक एक नवीन नातं देऊन जाते.",
    "author": "ग्रंथमित्र",
    "bookId": "69beeec9b277ab5c982c8edc",
    "bookTitle": "श्यामची आई",
    "category": "reading",
    "tags": ["वाचक", "नाते", "पुस्तके"],
    "likes": 153,
    "language": "marathi",
    "createdAt": {"$date": "2026-03-06T11:30:00.000Z"},
    "updatedAt": {"$date": "2026-03-06T11:30:00.000Z"}
  },
  {
    "text": "जिज्ञासा जिवंत असेल तर प्रत्येक अध्याय एक दार उघडतो.",
    "author": "ग्रंथमित्र",
    "bookId": "69beeec9b277ab5c982c8ed9",
    "bookTitle": "युगान्त",
    "category": "learning",
    "tags": ["जिज्ञासा", "अध्याय", "शिकणे"],
    "likes": 119,
    "language": "marathi",
    "createdAt": {"$date": "2026-03-07T05:50:00.000Z"},
    "updatedAt": {"$date": "2026-03-07T05:50:00.000Z"}
  },
  {
    "text": "दररोज थोडं वाचणंही, वर्षाअखेरीस मोठा बदल घडवू शकतं.",
    "author": "ग्रंथमित्र",
