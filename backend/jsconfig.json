{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "module": "commonjs",
    "target": "es2020",
    "moduleResolution": "node",
    "baseUrl": ".",
    "forceConsistentCasingInFileNames": true,
    "maxNodeModuleJsDepth": 0,
    "skipLibCheck": true
  },
  "include": [
    "server.js",
    "src/**/*.js"
  ],
  "exclude": [
    "node_modules"
  ]
}
