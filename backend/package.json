{
  "name": "granthmitra-backend",
  "version": "2.0.0",
  "description": "Express and MongoDB backend for the GranthMitra frontend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "check": "node --check server.js",
    "generate-books": "node src/scripts/generateBooksData.js",
    "import-books": "node src/scripts/importBooksFromCSV.js",
